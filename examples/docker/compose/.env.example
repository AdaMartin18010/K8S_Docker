# ============================================================================
# 环境变量示例文件
# 复制为 .env 并填写实际值
# ============================================================================

# 应用版本
VERSION=1.0.0

# 数据库配置
DB_USER=app
DB_PASSWORD=changeme_strong_password
DB_NAME=myapp

# Redis 配置
REDIS_PASSWORD=

# Grafana 配置
GRAFANA_USER=admin
GRAFANA_PASSWORD=changeme_strong_password

# 外部服务
EXTERNAL_API_KEY=
SMTP_PASSWORD=
